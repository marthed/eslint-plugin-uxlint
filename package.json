{
  "name": "eslint-plugin-uxlint",
  "description": "Customizable UX heuristic linting for web applications.",
  "version": "0.0.1",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marthed/eslint-plugin-uxlint.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/marthed/eslint-plugin-uxlint/issues"
  },
  "homepage": "https://github.com/marthed/eslint-plugin-uxlint#readme",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "ux",
    "lint",
    "static-analysis"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm test && npm run build",
    "test": "node --import tsx --test tests/*.test.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "playground:install": "cd examples/playground && npm install",
    "playground:dev": "cd examples/playground && npm run dev",
    "playground:lint": "cd examples/playground && npm run lint",
    "playground:lint:watch": "chokidar \"dist/**/*.{js,cjs,mjs,d.ts}\" \"examples/playground/**/*.{ts,tsx,js,jsx,json}\" -c \"npm run playground:lint\"",
    "playground:all": "npm run build && npm run playground:lint && concurrently -n BUILD,APP,LINT -c blue,green,yellow \"npm run dev\" \"npm run playground:dev\" \"npm run playground:lint:watch\""
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/parser": "^8.0.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  }
}
