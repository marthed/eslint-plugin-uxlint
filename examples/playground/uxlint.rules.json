{
  "version": 1,
  "config": {
    "designSystem": {
      "formComponents": ["Form"],
      "submitComponents": ["SubmitButton"],
      "errorComponents": ["InlineError", "ErrorMessage"],
      "errorSummaryComponents": ["FormErrorSummary"],
      "fieldComponents": ["TextField", "SelectField", "TextareaField"],
      "fieldErrorProps": ["error", "errorMessage", "invalid"]
    }
  },
  "rules": [
    {
      "id": "FORM-001",
      "title": "Avoid placeholder-only labels",
      "severity": "warn",
      "appliesTo": ["JSXOpeningElement"],
      "when": {
        "all": [
          { "in": ["jsx.tag", ["input", "textarea", "select"]] },
          { "hasAttr": "placeholder" },
          { "not": { "hasAnyAttr": ["aria-label", "aria-labelledby"] } }
        ]
      },
      "report": {
        "message": "Avoid placeholder-only labels. Provide a visible label or an accessible name."
      }
    },
    {
      "id": "BTN-001",
      "title": "Buttons should explicitly set type",
      "severity": "warn",
      "appliesTo": ["JSXOpeningElement"],
      "when": {
        "all": [
          { "eq": ["jsx.tag", "button"] },
          { "not": { "hasAttr": "type" } }
        ]
      },
      "report": {
        "message": "<button> should explicitly set type=\"button\" or type=\"submit\"."
      }
    },
    {
      "id": "IMG-001",
      "title": "Images must have alt text",
      "severity": "warn",
      "appliesTo": ["JSXOpeningElement"],
      "when": {
        "all": [
          { "eq": ["jsx.tag", "img"] },
          { "not": { "hasAttr": "alt" } }
        ]
      },
      "report": {
        "message": "<img> must have alt text."
      }
    },
    {
      "id": "ICON-001",
      "title": "Icon buttons must have accessible labels",
      "severity": "warn",
      "appliesTo": ["JSXOpeningElement"],
      "when": {
        "all": [
          { "in": ["jsx.componentName", ["IconButton", "IconOnlyButton"]] },
          { "not": { "hasAnyAttr": ["aria-label", "aria-labelledby", "label", "title"] } }
        ]
      },
      "report": {
        "message": "Icon-only buttons must have an accessible label."
      }
    }
  ]
}
